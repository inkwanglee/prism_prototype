{
  "realm": "prism",
  "enabled": true,
  "displayName": "PRISM",
  "displayNameHtml": "<strong>PRISM</strong>",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      { "name": "geodesK_user", "description": "Any signed-in user coming from GeoDesk SSO" },
      { "name": "data_steward", "description": "Owns schemas, approvals, and promotion gates" },
      { "name": "data_engineer", "description": "Builds ingestion and validation" },
      { "name": "exploration_geologist", "description": "Inputs field data and reviews QAQC" },
      { "name": "lab_integration_engineer", "description": "Connects lab feeds" },
      { "name": "platform_sre", "description": "Observability, performance, backups" },
      { "name": "security_admin", "description": "Roles, policies, audits" },
      { "name": "guest", "description": "Read-only access — can view all pages but cannot create, edit, or delete data" }
    ]
  },
  "users": [
    {
      "username": "orefox1",
      "email": "orefox1@prism.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Orefox",
      "lastName": "User 1",
      "credentials": [{ "type": "password", "value": "test1234", "temporary": false }],
      "realmRoles": ["data_steward"]
    },
    {
      "username": "orefox2",
      "email": "orefox2@prism.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Orefox",
      "lastName": "User 2",
      "credentials": [{ "type": "password", "value": "test1234", "temporary": false }],
      "realmRoles": ["data_steward"]
    },
    {
      "username": "guest",
      "email": "guest@prism.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Guest",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "guest123", "temporary": false }],
      "realmRoles": ["guest"]
    }
  ],
  "clients": [
    {
      "clientId": "prism-web",
      "name": "PRISM Web Application",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "prism-dev-secret-2025",
      "redirectUris": [
        "http://localhost:8000/oidc/callback/",
        "http://localhost:8000/*",
        "https://prism-web.kindground-d178727f.australiaeast.azurecontainerapps.io/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "https://prism-web.kindground-d178727f.australiaeast.azurecontainerapps.io"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "prism_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "prism_roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "scopeMappings": [
    {
      "client": "prism-web",
      "roles": [
        "geodesK_user", "data_steward", "data_engineer",
        "exploration_geologist", "lab_integration_engineer",
        "platform_sre", "security_admin", "guest"
      ]
    }
  ]
}
