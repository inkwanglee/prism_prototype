DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=prism_site.settings
DATABASE_URL=postgres://prism:prism@localhost:5432/prism
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123

# OIDC - Keycloak 설정 (설치 후 realm 생성 필요)
OIDC_ISSUER=http://keycloak:8080/realms/prism
OIDC_CLIENT_ID=prism-web
OIDC_CLIENT_SECRET=devsecret
OIDC_AUDIENCE=prism-api

# 개발 환경에서는 OIDC 비활성화 옵션
DISABLE_OIDC=True