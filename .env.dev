DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=prism_site.settings
DATABASE_URL=postgres://prism:prism@db:5432/prism
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123

# ===== OIDC - Keycloak SSO Configuration =====
# Browser-facing URL (user's browser redirects here)
OIDC_ISSUER=http://localhost:8080/realms/prism
OIDC_CLIENT_ID=prism-web
OIDC_CLIENT_SECRET=prism-dev-secret-2025
OIDC_AUDIENCE=prism-web
# Note: OIDC_ISSUER_INTERNAL is set in docker-compose.yml
# for server-to-server calls inside Docker network

# SSO toggle: False = SSO enabled, True = Django admin login
DISABLE_OIDC=False

# For Docker: False (uses PostgreSQL). For local dev: True (uses SQLite)
USE_SQLITE=False
