DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=prism_site.settings
DATABASE_URL=postgres://prism:prism@db:5432/prism
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123

# OIDC - Keycloak configuration (requires creating a realm after installation)
OIDC_ISSUER=http://keycloak:8080/realms/prism
OIDC_CLIENT_ID=prism-web
OIDC_CLIENT_SECRET=devsecret
OIDC_AUDIENCE=prism-api

# Option to disable OIDC in the development environment
DISABLE_OIDC=True